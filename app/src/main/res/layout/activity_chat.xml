<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#F3F4F6">

    <!-- Top AppBar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:elevation="4dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <!-- Left: Logo + Title block -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/university_logo"
                    android:scaleType="fitCenter"
                    android:layout_marginEnd="10dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TPC Query Assistant"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Training &amp; Placement Cell"
                        android:textSize="11sp"
                        android:textColor="#6B7280" />
                </LinearLayout>
            </LinearLayout>

            <!-- Right: User info + actions (use menu or custom view) -->
            <!-- These buttons are positioned via the Toolbar's action items in code -->
            <!-- See menu/menu_chat.xml for Reset and Logout actions -->

        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Human Escalation Banner -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardHumanRequired"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="10dp"
            app:cardBackgroundColor="#FEE2E2"
            app:strokeColor="#FCA5A5"
            app:strokeWidth="1dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:text="⚠"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tvHumanRequired"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="This query requires TPC coordinator intervention."
                    android:textSize="13sp"
                    android:textColor="#B91C1C"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Welcome Header (shown when chat is empty) -->
        <LinearLayout
            android:id="@+id/layoutWelcome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="24dp">

            <!-- Bot Avatar -->
            <FrameLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_marginBottom="16dp">

                <View
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/bg_bot_avatar" />

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_robot"
                    android:textSize="28sp"
                    android:gravity="center" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome to TPC Query Assistant"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ask me anything about placement policies, eligibility, and procedures"
                android:textSize="13sp"
                android:textColor="#6B7280"
                android:gravity="center"
                android:layout_marginBottom="20dp" />

            <!-- Quick Action Chips -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:chipSpacingHorizontal="8dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCgpa"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CGPA Rule?"
                    android:textSize="13sp"
                    android:textColor="#374151"
                    app:chipBackgroundColor="#FFFFFF"
                    app:chipStrokeColor="#D1D5DB"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="20dp"
                    style="@style/Widget.MaterialComponents.Chip.Action" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipDeadline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Deadline?"
                    android:textSize="13sp"
                    android:textColor="#374151"
                    app:chipBackgroundColor="#FFFFFF"
                    app:chipStrokeColor="#D1D5DB"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="20dp"
                    style="@style/Widget.MaterialComponents.Chip.Action" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipMultipleOffers"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Multiple offers?"
                    android:textSize="13sp"
                    android:textColor="#374151"
                    app:chipBackgroundColor="#FFFFFF"
                    app:chipStrokeColor="#D1D5DB"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="20dp"
                    style="@style/Widget.MaterialComponents.Chip.Action" />

            </com.google.android.material.chip.ChipGroup>
        </LinearLayout>

        <!-- Chat RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvChat"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:clipToPadding="false" />

        <!-- Bottom Input Area -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="0dp"
            app:cardElevation="12dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="10dp"
                android:paddingBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- Message Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilMessage"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="10dp"
                        app:boxCornerRadiusTopStart="24dp"
                        app:boxCornerRadiusTopEnd="24dp"
                        app:boxCornerRadiusBottomStart="24dp"
                        app:boxCornerRadiusBottomEnd="24dp"
                        app:boxStrokeColor="#E5E7EB"
                        app:boxStrokeWidth="1dp"
                        app:boxBackgroundColor="#F9FAFB"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etMessage"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Ask about CGPA, registration, rules, etc..."
                            android:inputType="textMultiLine|textCapSentences"
                            android:maxLines="4"
                            android:textSize="14sp"
                            android:textColor="#1A1A2E"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="12dp"
                            android:paddingBottom="12dp"
                            android:background="@null" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Send Button -->
                    <com.google.android.material.floatingactionbutton.FloatingActionButton
                        android:id="@+id/btnSend"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/baseline_send"
                        app:backgroundTint="#F5821F"
                        app:tint="#FFFFFF"
                        app:fabSize="normal"
                        app:maxImageSize="24dp"
                        app:elevation="2dp" />

                </LinearLayout>

                <!-- Hint below input -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:text="Press Enter to send · Shift+Enter for new line"
                    android:textSize="11sp"
                    android:textColor="#9CA3AF"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:text="AI Assistant can make mistakes. Check important info"
                    android:textSize="11sp"
                    android:textColor="#9CA3AF"
                    android:layout_marginTop="2dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>