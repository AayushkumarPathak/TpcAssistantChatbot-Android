<?xml version="1.0" encoding="utf-8"?>
<!-- Add / merge into your res/values/themes.xml -->
<resources>

    <!-- Main app theme - use MaterialComponents for all Material widgets -->
    <style name="Theme.TPCAssistant" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/tpc_orange</item>
        <item name="colorPrimaryVariant">@color/tpc_orange_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/tpc_orange</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:windowBackground">@color/surface</item>
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- TextInputLayout focused color -->
        <item name="colorControlActivated">@color/tpc_orange</item>
    </style>

    <!-- Toolbar style used in ChatActivity -->
    <style name="TPCToolbar" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">@color/white</item>
        <item name="titleTextColor">@color/text_primary</item>
    </style>

</resources>